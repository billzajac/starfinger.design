[lightbox-toggle]{cursor:pointer}.c-lightbox{font-family:Arial,helvetica neue,Helvetica,sans-serif;pointer-events:none;position:fixed;opacity:0;width:100vw;height:100vh;z-index:9000000;top:0;left:0;right:0;bottom:0;background-color:rgba(255,255,255,.3)!important;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);display:flex;flex-direction:column;justify-content:center;align-items:center;cursor:pointer;transition:opacity .3s}.c-lightbox.open{opacity:1;pointer-events:all}.c-lightbox .c-lightbox__container{width:100%;height:100%;background-color:initial!important}.c-lightbox .c-lightbox__close{position:absolute;top:12px;right:16px;z-index:10;font-size:36px;line-height:1;color:rgba(0,0,0,.4);cursor:pointer;width:48px;height:48px;display:flex;justify-content:center;align-items:center;border-radius:50%;background-color:initial!important;transition:color .2s,background-color .2s}.c-lightbox .c-lightbox__close:hover{color:rgba(0,0,0,.7);background-color:rgba(0,0,0,8%)!important}.c-lightbox .swiper{width:100%;height:100%;cursor:default;background-color:initial!important}.c-lightbox .swiper-wrapper{background-color:initial!important}.c-lightbox .swiper-slide{display:flex;justify-content:center;align-items:center;background-color:initial!important}.c-lightbox .swiper-pagination{display:none}.c-lightbox .swiper-button-next,.c-lightbox .swiper-button-prev{color:rgba(0,0,0,.2);transition:color .2s}.c-lightbox .swiper-button-next:hover,.c-lightbox .swiper-button-prev:hover{color:rgba(0,0,0,.5)}.c-lightbox .swiper-button-next:after,.c-lightbox .swiper-button-prev:after{font-size:20px}.c-lightbox .c-lightbox__image{display:flex;justify-content:center;align-items:center;cursor:default}.c-lightbox .c-lightbox__image img{object-fit:contain;max-height:92vh;max-width:92vw;width:auto!important;height:auto!important;box-shadow:0 8px 40px rgba(0,0,0,.15)}